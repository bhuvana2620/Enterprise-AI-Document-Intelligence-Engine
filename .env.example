```env
# ---------------------------------------------------
# Pinecone Vector Database
# ---------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=ai-document-intelligence
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_UPSERT_BATCH_SIZE=100
PINECONE_NAMESPACE=default-session
ENABLE_HYBRID_SEARCH=false

# ---------------------------------------------------
# Embeddings
# ---------------------------------------------------
# "sentence_transformer" is recommended for real semantic search.
# "hash" is a lightweight fallback for constrained environments.
EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_SEQ_LENGTH=512

# ---------------------------------------------------
# Optional Retrieval Enhancements
# ---------------------------------------------------
ENABLE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-base

# ---------------------------------------------------
# Optional OCR
# ---------------------------------------------------
# Keep disabled by default for lightweight Hugging Face deployment.
ENABLE_OCR=false
OCR_MIN_TEXT_LENGTH=200

# ---------------------------------------------------
# LLM Provider
# ---------------------------------------------------
# Options:
# gemini = use Gemini only
# grok   = use xAI Grok only
# mock   = use mock responses only
# auto   = Gemini first, Grok fallback, then mock fallback
LLM_PROVIDER=auto
MOCK_LLM_MODE=false

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-1.5-flash

# xAI Grok fallback
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

# LLM retry and fallback behavior
LLM_MAX_RETRIES=3
SHOW_LLM_FALLBACK_REASON=true

# ---------------------------------------------------
# Backend / Frontend Single Container Deployment
# ---------------------------------------------------
HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=7860

# Local development only.
# Leave empty in Hugging Face Spaces unless you are calling an external backend.
API_BASE_URL=

# ---------------------------------------------------
# Upload Retry Settings
# ---------------------------------------------------
MAX_UPLOAD_RETRIES=3
UPLOAD_BASE_RETRY_DELAY_SECONDS=2

# ---------------------------------------------------
# Evaluation
# ---------------------------------------------------
EVAL_NAMESPACE=
EVAL_CATEGORY_FILTER=
EVAL_TOP_K=3
RUN_EVAL=false
```
