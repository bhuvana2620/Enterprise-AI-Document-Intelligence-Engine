# ---------------------------------------------------
# Pinecone (Vector Database)
# ---------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=ai-document-intelligence
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
EMBEDDING_DIMENSION=384
PINECONE_UPSERT_BATCH_SIZE=100
PINECONE_NAMESPACE=default-session
ENABLE_HYBRID_SEARCH=false

# ---------------------------------------------------
# Embeddings
# ---------------------------------------------------
# "sentence_transformer" for real semantic embeddings (recommended on
# Hugging Face Spaces, which has enough RAM unlike Render free tier).
# "hash" is a near-zero-memory fallback used only for constrained environments.
EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# ---------------------------------------------------
# LLM Provider
# ---------------------------------------------------
LLM_PROVIDER=gemini
MOCK_LLM_MODE=false

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

# ---------------------------------------------------
# Backend / Frontend (single-container deployment)
# ---------------------------------------------------
HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=7860

# Local dev only — leave unset in containerized deployments.
API_BASE_URL=

# ---------------------------------------------------
# Evaluation
# ---------------------------------------------------
EVAL_NAMESPACE=
EVAL_CATEGORY_FILTER=
EVAL_TOP_K=3
RUN_RAGAS=false
