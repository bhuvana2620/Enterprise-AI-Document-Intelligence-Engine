# ---------------------------------------------------
# Pinecone
# ---------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=ai-document-intelligence
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
EMBEDDING_DIMENSION=384
PINECONE_UPSERT_BATCH_SIZE=100
PINECONE_NAMESPACE=default-session
ENABLE_HYBRID_SEARCH=false

# ---------------------------------------------------
# LLM Provider
# ---------------------------------------------------
LLM_PROVIDER=gemini
MOCK_LLM_MODE=false

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

# ---------------------------------------------------
# Backend / Frontend
# ---------------------------------------------------
HOST=0.0.0.0
PORT=8000

# Local dev
API_BASE_URL=http://127.0.0.1:8000

# Render-only optional internal backend reference.
# Usually set automatically from render.yaml.
API_BASE_HOSTPORT=

# ---------------------------------------------------
# Evaluation
# ---------------------------------------------------
EVAL_NAMESPACE=
EVAL_CATEGORY_FILTER=
EVAL_TOP_K=3
RUN_RAGAS=false